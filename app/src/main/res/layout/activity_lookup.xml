<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="#1A1A2E"
        app:title="CONSULTA"
        app:titleTextColor="@android:color/white"
        app:navigationIcon="@drawable/ic_back"
        app:navigationIconTint="@android:color/white" />

    <!-- Search bar -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="8dp"
        android:paddingVertical="6dp"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editSearch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/search_hint"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:textSize="15sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Scan prompt -->
    <TextView
        android:id="@+id/txtScanPrompt"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="@string/scan_product"
        android:textSize="22sp"
        android:textColor="#999" />

    <!-- Product result -->
    <ScrollView
        android:id="@+id/scrollResult"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- PRICE - BIG -->
            <TextView
                android:id="@+id/txtPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textSize="48sp"
                android:textStyle="bold"
                android:textColor="#1B5E20"
                android:maxLines="1"
                app:autoSizeTextType="uniform"
                app:autoSizeMinTextSize="28sp"
                app:autoSizeMaxTextSize="48sp" />

            <TextView
                android:id="@+id/txtPriceLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="USD"
                android:textSize="14sp"
                android:textColor="#888" />

            <!-- Product image -->
            <ImageView
                android:id="@+id/imgProduct"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                android:layout_marginTop="8dp"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:contentDescription="Producto" />

            <!-- Product name -->
            <TextView
                android:id="@+id/txtProductName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#333"
                android:layout_marginTop="8dp"
                android:maxLines="2"
                android:ellipsize="end" />

            <!-- Variant -->
            <TextView
                android:id="@+id/txtVariant"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textSize="16sp"
                android:textColor="#BF360C"
                android:textStyle="bold"
                android:layout_marginTop="4dp"
                android:visibility="gone" />

            <!-- Code -->
            <TextView
                android:id="@+id/txtProductCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textSize="13sp"
                android:textColor="#888"
                android:layout_marginTop="2dp" />

            <!-- Category / Brand -->
            <TextView
                android:id="@+id/txtCategoryBrand"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textSize="12sp"
                android:textColor="#888"
                android:layout_marginTop="2dp"
                android:visibility="gone" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginVertical="10dp" />

            <!-- Variants + Stock section -->
            <TextView
                android:id="@+id/txtStockHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="STOCK POR ALMACEN"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#888"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:id="@+id/layoutStock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- Location section -->
            <TextView
                android:id="@+id/txtLocationHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="UBICACION"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#888"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="6dp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/layoutLocations"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>
    </ScrollView>

    <!-- Not found -->
    <TextView
        android:id="@+id/txtNotFound"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="24dp"
        android:text="@string/product_not_found"
        android:textSize="18sp"
        android:textColor="@android:color/holo_red_dark"
        android:visibility="gone" />
</LinearLayout>
