<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?actionBarSize"
        android:background="?colorPrimary"
        app:title="@string/app_name"
        app:titleTextColor="@android:color/white"
        app:menu="@menu/menu_home" />

    <!-- Sync status -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="?colorSurfaceVariant">

        <TextView
            android:id="@+id/txtSyncStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/never_synced"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSync"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/sync"
            android:textSize="12sp"
            style="@style/Widget.Material3.Button.TonalButton" />
    </LinearLayout>

    <!-- Warehouse selector -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/warehouse"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginEnd="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnWarehouse"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="@string/select_warehouse"
            android:textSize="14sp"
            style="@style/Widget.Material3.Button.OutlinedButton" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0" />

    <!-- Module buttons - 3x2 grid -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Row 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLookup"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="@string/lookup_title"
                android:textSize="16sp"
                app:icon="@android:drawable/ic_menu_search"
                app:iconGravity="top"
                app:iconSize="28dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPriceCheck"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="@string/price_checker_title"
                android:textSize="16sp"
                app:backgroundTint="#D84315"
                app:icon="@android:drawable/ic_menu_view"
                app:iconGravity="top"
                app:iconSize="28dp" />
        </LinearLayout>

        <!-- Row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCount"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="@string/count_title"
                android:textSize="16sp"
                app:backgroundTint="#0F3460"
                app:icon="@android:drawable/ic_menu_agenda"
                app:iconGravity="top"
                app:iconSize="28dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTransfer"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="@string/transfer_title"
                android:textSize="16sp"
                app:backgroundTint="#533483"
                app:icon="@android:drawable/ic_menu_send"
                app:iconGravity="top"
                app:iconSize="28dp" />
        </LinearLayout>

        <!-- Row 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnShelves"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="@string/shelves_title"
                android:textSize="16sp"
                app:backgroundTint="#00695C"
                app:icon="@android:drawable/ic_menu_sort_by_size"
                app:iconGravity="top"
                app:iconSize="28dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLocation"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="@string/location_finder_title"
                android:textSize="16sp"
                app:backgroundTint="#37474F"
                app:icon="@android:drawable/ic_menu_myplaces"
                app:iconGravity="top"
                app:iconSize="28dp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
