<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="#4A148C"
        app:title="TRANSFERENCIAS"
        app:titleTextColor="@android:color/white"
        app:navigationIcon="@drawable/ic_back"
        app:navigationIconTint="@android:color/white" />

    <LinearLayout
        android:id="@+id/layoutNewTransfer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Warehouse selectors - compact -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="6dp"
            android:paddingVertical="6dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFrom"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="3dp"
                android:text="ORIGEN"
                android:textSize="11sp"
                android:textStyle="bold"
                app:backgroundTint="#4A148C"
                app:cornerRadius="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="→"
                android:textSize="20sp"
                android:textColor="#4A148C"
                android:layout_gravity="center"
                android:paddingHorizontal="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTo"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="3dp"
                android:text="DESTINO"
                android:textSize="11sp"
                android:textStyle="bold"
                app:backgroundTint="#00695C"
                app:cornerRadius="4dp" />
        </LinearLayout>

        <!-- Scan prompt -->
        <TextView
            android:id="@+id/txtTransferPrompt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="8dp"
            android:text="Escanea los productos a transferir"
            android:textSize="13sp"
            android:textColor="#888" />

        <!-- Scanned items -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerTransferItems"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="6dp" />

        <!-- Bottom bar -->
        <LinearLayout
            android:id="@+id/layoutTransferBottom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:background="#EEEEEE"
            android:gravity="center_vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/txtTransferTotal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="13sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCreateTransfer"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="TRANSFERIR"
                android:textSize="14sp"
                android:textStyle="bold"
                app:backgroundTint="#4A148C"
                app:cornerRadius="4dp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
