<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?actionBarSize"
        android:background="#533483"
        app:title="@string/transfer_title"
        app:titleTextColor="@android:color/white"
        app:navigationIcon="@drawable/ic_back"
        app:navigationIconTint="@android:color/white" />

    <!-- Tab-like buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNewTransfer"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="@string/new_transfer"
            android:textSize="13sp"
            app:backgroundTint="#533483" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnListTransfers"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="@string/pending_transfers"
            android:textSize="13sp"
            style="@style/Widget.Material3.Button.OutlinedButton" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0" />

    <!-- New transfer form -->
    <LinearLayout
        android:id="@+id/layoutNewTransfer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Warehouse selectors -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/from_warehouse"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFrom"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="@string/select_warehouse"
                    android:textSize="12sp"
                    style="@style/Widget.Material3.Button.OutlinedButton" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/to_warehouse"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTo"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="@string/select_warehouse"
                    android:textSize="12sp"
                    style="@style/Widget.Material3.Button.OutlinedButton" />
            </LinearLayout>
        </LinearLayout>

        <!-- Scan prompt -->
        <TextView
            android:id="@+id/txtTransferPrompt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="16dp"
            android:text="Selecciona almacenes y escanea productos"
            android:textSize="14sp"
            android:textColor="#888" />

        <!-- Scanned items -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerTransferItems"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="8dp" />

        <!-- Bottom -->
        <LinearLayout
            android:id="@+id/layoutTransferBottom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:background="?colorSurfaceVariant"
            android:gravity="center_vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/txtTransferTotal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCreateTransfer"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="@string/create_transfer"
                android:textSize="14sp"
                app:backgroundTint="#533483" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
