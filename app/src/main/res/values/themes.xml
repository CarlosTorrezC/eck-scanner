<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ECKScanner" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">#1A1A2E</item>
        <item name="colorPrimaryContainer">#16213E</item>
        <item name="colorOnPrimaryContainer">@android:color/white</item>
        <item name="colorSecondary">#E94560</item>
        <item name="colorSecondaryContainer">#E94560</item>
        <item name="colorOnSecondaryContainer">@android:color/white</item>
        <item name="colorSurface">@android:color/white</item>
        <item name="colorOnSurface">#1A1A2E</item>
        <item name="colorSurfaceVariant">#EEEEEE</item>
        <item name="android:statusBarColor">?colorPrimary</item>
    </style>

    <!-- Industrial flat button for home grid -->
    <style name="GridButton" parent="Widget.Material3.Button">
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">true</item>
        <item name="cornerRadius">6dp</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <!-- Compact toolbar for industrial screens -->
    <style name="CompactToolbar">
        <item name="android:minHeight">44dp</item>
    </style>
</resources>
